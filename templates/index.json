            "question": "How long does shipping take?",
            "answer": "<p>We offer free shipping on all orders. Most mattresses ship within 3-5 business days and arrive within 7-10 business days.</p>"
          }
        },
        "faq-2": {
          "type": "faq_item",
          "settings": {
            "question": "What is your return policy?",
            "answer": "<p>We offer a 120-day sleep trial. If you're not satisfied with your mattress, you can return it for a full refund.</p>"
          }
        },
        "faq-3": {
          "type": "faq_item",
          "settings": {
            "question": "Do you offer financing?",
            "answer": "<p>Yes! We offer 0% interest financing on qualifying purchases. Apply at checkout to see if you qualify.</p>"
          }
        },
        "faq-4": {
          "type": "faq_item",
          "settings": {
            "question": "What warranty do you offer?",
            "answer": "<p>All our mattresses come with a 10-year limited warranty covering manufacturing defects and body impressions.</p>"
          }
        },
        "faq-5": {
          "type": "faq_item",
          "settings": {
            "question": "Can I try the mattress before buying?",
            "answer": "<p>While we don't have physical showrooms, our 120-day sleep trial lets you try the mattress in the comfort of your own home.</p>"
          }
        },
