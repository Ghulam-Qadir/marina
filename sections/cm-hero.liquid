    },
    {
      "type": "header",
      "content": "Badge card 3"
    },
    {
      "type": "image_picker",
      "id": "badge_icon_3",
      "label": "Badge icon"
    },
    {
      "type": "text",
      "id": "badge_label_3_top",
      "label": "Top label",
      "default": "EXPERT"
    },
    {
      "type": "text",
      "id": "badge_label_3_bottom",
      "label": "Bottom label",
      "default": "GUIDANCE"
    },
    {
      "type": "header",
      "content": "Bottom feature 1"
    },
    {
      "type": "image_picker",
      "id": "feature_icon_1",
      "label": "Feature icon"
    },
    {
      "type": "text",
      "id": "feature_small_1",
      "label": "Small text",
      "default": "FREE"
    },
    {
      "type": "text",
      "id": "feature_big_1",
      "label": "Big text",
      "default": "SHIPPING"
    },
    {
      "type": "header",
      "content": "Bottom feature 2"
    },
    {
      "type": "image_picker",
      "id": "feature_icon_2",
