    },
    {
      "type": "text",
      "id": "feature_small_2",
      "label": "Small text",
      "default": "EASY"
    },
    {
      "type": "text",
      "id": "feature_big_2",
      "label": "Big text",
      "default": "RETURN"
    },
    {
      "type": "header",
      "content": "Bottom feature 3"
    },
    {
      "type": "image_picker",
      "id": "feature_icon_3",
      "label": "Feature icon"
    },
    {
      "type": "text",
      "id": "feature_small_3",
      "label": "Small text",
      "default": "QUICK"
