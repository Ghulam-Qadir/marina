{{ 'cm-product-tabs.css' | asset_url | stylesheet_tag }}

{%- assign tab_blocks = section.blocks | where: "type", "tab" -%}

<section class="cm-pt" id="CMProductTabs-{{ section.id }}">
  <div class="ps-container">
    {%- comment -%} Section header {%- endcomment -%}
    {%- if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.description != blank -%}
      <div class="cm-pt-header">
        {%- if section.settings.badge_image != blank -%}
          <div class="cm-pt-badge">
            <img src="{{ section.settings.badge_image | image_url: width: 140 }}" alt="{{ section.settings.badge_image.alt | escape }}" width="70" height="{{ 70 | divided_by: section.settings.badge_image.aspect_ratio | round }}" loading="lazy">
          </div>
        {%- endif -%}
        <div class="cm-pt-header-text">
          {%- if section.settings.eyebrow != blank -%}
            <div class="cm-pt-eyebrow">{{ section.settings.eyebrow }}</div>
          {%- endif -%}
          {%- if section.settings.heading != blank -%}
            <h2 class="cm-pt-heading">{{ section.settings.heading }}</h2>
          {%- endif -%}
          {%- if section.settings.description != blank -%}
            <p class="cm-pt-description">{{ section.settings.description }}</p>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}

    {%- comment -%} Tab pills {%- endcomment -%}
    {%- if tab_blocks.size > 0 -%}
      <div class="cm-pt-pills" role="tablist">
        {%- for block in tab_blocks -%}
          <button
            class="cm-pt-pill{% if forloop.first %} active{% endif %}"
            role="tab"
            data-tab="{{ block.id }}"
            aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
            {{ block.shopify_attributes }}
          >
            {{ block.settings.tab_name }}
          </button>
        {%- endfor -%}
      </div>

      {%- comment -%} Tab panels {%- endcomment -%}
      {%- for block in tab_blocks -%}
        {%- assign collection = collections[block.settings.collection] -%}
        <div
          class="cm-pt-panel{% if forloop.first %} active{% endif %}"
          role="tabpanel"
          data-panel="{{ block.id }}"
        >
          {%- comment -%} Section controls {%- endcomment -%}
          <div class="cm-pt-controls">
            <div class="cm-pt-controls-left">
              {%- if block.settings.tab_name != blank -%}
                <h3 class="cm-pt-section-title">{{ block.settings.tab_name }}</h3>
              {%- endif -%}
              {%- if block.settings.view_all_link != blank -%}
                <a href="{{ block.settings.view_all_link }}" class="cm-pt-view-all">
                  {{ block.settings.view_all_text | default: "View All" }}
                </a>
              {%- endif -%}
            </div>
            <div class="cm-pt-arrows">
              <button class="cm-pt-arrow cm-pt-arrow-prev" aria-label="Previous" data-swiper-prev="{{ block.id }}">&#8592;</button>
              <button class="cm-pt-arrow cm-pt-arrow-next" aria-label="Next" data-swiper-next="{{ block.id }}">&#8594;</button>
            </div>
          </div>

          {%- comment -%} Product grid / swiper {%- endcomment -%}
          {%- if collection != blank and collection.products.size > 0 -%}
            <div class="cm-pt-swiper" data-swiper="{{ block.id }}">
              <div class="cm-pt-grid">
                {%- for product in collection.products limit: 6 -%}
                  <div class="cm-product-item">
                    <a href="{{ product.url }}" class="cm-product-image">
                      {%- if product.featured_image != blank -%}
                        <img
                          src="{{ product.featured_image | image_url: width: 600 }}"
                          alt="{{ product.featured_image.alt | escape }}"
                          width="{{ product.featured_image.width }}"
                          height="{{ product.featured_image.height }}"
                          loading="lazy"
                        >
                      {%- else -%}
                        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                      {%- endif -%}
                    </a>

                    <div class="cm-product-details">
                      {%- if product.title != blank -%}
                        <h4 class="cm-product-title">
                          <a href="{{ product.url }}">{{ product.title }}</a>
                        </h4>
                      {%- endif -%}

                      {%- comment -%} Star rating (static placeholder) {%- endcomment -%}
                      <div class="cm-product-reviews">
                        <div class="cm-product-stars">
                          {%- for s in (1..5) -%}
                            <svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M10 15.27L16.18 19l-1.64-7.03L20 7.24l-7.19-.62L10 0 7.19 6.62 0 7.24l5.46 4.73L3.82 19z"/></svg>
                          {%- endfor -%}
                        </div>
                        <span class="cm-product-review-count">({{ product.metafields.reviews.rating_count | default: 0 }})</span>
                      </div>

                      {%- comment -%} Price {%- endcomment -%}
                      <div class="cm-product-price">
                        {%- if product.compare_at_price > product.price -%}
                          <span class="cm-product-price-original">{{ product.compare_at_price | money }}</span>
                        {%- endif -%}
                        <span class="cm-product-price-current">{{ product.price | money }}</span>
                      </div>
                      <div class="cm-product-price-sub">Starting Price</div>

                      {%- comment -%} Size options {%- endcomment -%}
                      {%- for option in product.options_with_values -%}
                        {%- if option.name == "Size" -%}
                          <div class="cm-product-sizes">
                            {%- for value in option.values -%}
                              <button class="cm-product-size">{{ value }}</button>
                            {%- endfor -%}
                          </div>
                        {%- endif -%}
                      {%- endfor -%}

                      {%- comment -%} Brand + Shop now {%- endcomment -%}
                      <div class="cm-product-brand-row">
                        {%- if product.vendor != blank -%}
                          <div class="cm-product-brand">
                            <span class="cm-product-brand-label">Brand</span>
                            <span class="cm-product-brand-name">{{ product.vendor }}</span>
                          </div>
                        {%- endif -%}
                        <a href="{{ product.url }}" class="cm-product-shop-now">Shop Now</a>
                      </div>
                    </div>
                  </div>
                {%- endfor -%}
              </div>
            </div>
          {%- else -%}
            <div class="cm-pt-swiper">
              <div class="cm-pt-grid">
                {%- for i in (1..3) -%}
                  <div class="cm-product-item">
                    <div class="cm-product-image">
                      {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                    </div>
                    <div class="cm-product-details">
                      <h4 class="cm-product-title">Sample product</h4>
                      <div class="cm-product-price">
                        <span class="cm-product-price-current">$0.00</span>
                      </div>
                    </div>
                  </div>
                {%- endfor -%}
              </div>
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var section = document.getElementById('CMProductTabs-{{ section.id }}');
    if (!section) return;

    var pills = section.querySelectorAll('.cm-pt-pill');
    var panels = section.querySelectorAll('.cm-pt-panel');

    pills.forEach(function (pill) {
      pill.addEventListener('click', function () {
        var target = this.getAttribute('data-tab');

        pills.forEach(function (p) {
          p.classList.remove('active');
          p.setAttribute('aria-selected', 'false');
        });
        this.classList.add('active');
        this.setAttribute('aria-selected', 'true');

        panels.forEach(function (panel) {
          panel.classList.remove('active');
          if (panel.getAttribute('data-panel') === target) {
            panel.classList.add('active');
          }
        });
      });
    });

    var swiperOffsets = {};

    section.querySelectorAll('.cm-pt-arrow-next').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var id = this.getAttribute('data-swiper-next');
        var swiper = section.querySelector('[data-swiper="' + id + '"]');
        if (!swiper) return;
        var grid = swiper.querySelector('.cm-pt-grid');
        var card = grid.querySelector('.cm-product-item');
        if (!card) return;
        var step = card.offsetWidth + 24;
        var maxScroll = grid.scrollWidth - swiper.offsetWidth;
        swiperOffsets[id] = Math.min((swiperOffsets[id] || 0) + step, maxScroll);
        grid.style.transform = 'translateX(-' + swiperOffsets[id] + 'px)';
      });
    });

    section.querySelectorAll('.cm-pt-arrow-prev').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var id = this.getAttribute('data-swiper-prev');
        var swiper = section.querySelector('[data-swiper="' + id + '"]');
        if (!swiper) return;
        var grid = swiper.querySelector('.cm-pt-grid');
        var card = grid.querySelector('.cm-product-item');
        if (!card) return;
        var step = card.offsetWidth + 24;
        swiperOffsets[id] = Math.max((swiperOffsets[id] || 0) - step, 0);
        grid.style.transform = 'translateX(-' + swiperOffsets[id] + 'px)';
      });
    });
  });
</script>

{% schema %}
{
  "name": "CM Product Tabs",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "image_picker",
      "id": "badge_image",
      "label": "Badge image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "PRODUCTS TO"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "IMPROVE YOUR SLEEP"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Discover our curated selection of sleep essentials designed to give you the rest you deserve."
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "tab_name",
          "label": "Tab name",
          "default": "Mattress"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "url",
          "id": "view_all_link",
          "label": "View all link"
        },
        {
          "type": "text",
          "id": "view_all_text",
          "label": "View all text",
          "default": "View All"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "CM Product Tabs",
      "blocks": [
        {
          "type": "tab",
          "settings": {
            "tab_name": "Mattress"
          }
        },
        {
          "type": "tab",
          "settings": {
            "tab_name": "Adjustable Bases"
          }
        },
        {
          "type": "tab",
          "settings": {
            "tab_name": "Soft Pillows"
          }
        },
        {
          "type": "tab",
          "settings": {
            "tab_name": "Bedding"
          }
        }
      ]
    }
  ]
}
{% endschema %}
