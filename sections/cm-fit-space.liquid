{{ 'cm-fit-space.css' | asset_url | stylesheet_tag }}

{%- if section.settings.eyebrow != blank -%}
  {% assign cm_eyebrow = section.settings.eyebrow %}
{%- else -%}
  {% assign cm_eyebrow = 'FIND YOUR PERFECT FIT' %}
{%- endif -%}

{%- if section.settings.heading != blank -%}
  {% assign cm_heading = section.settings.heading %}
{%- else -%}
  {% assign cm_heading = 'FIT YOUR SPACE' %}
{%- endif -%}

<div class="cm-fit-section">
  <div class="cm-container">
    <div class="cm-fit-header">
      {% if section.settings.badge_image != blank %}
        <div class="cm-fit-badge">
          {{ section.settings.badge_image | image_url: width: 144 | image_tag: loading: 'lazy' }}
        </div>
      {% endif %}
      <div>
        <div class="cm-eyebrow">{{ cm_eyebrow }}</div>
        <h2 class="cm-section-title">{{ cm_heading }}</h2>
        {% if section.settings.description != blank %}
          <p class="cm-section-sub">{{ section.settings.description }}</p>
        {% endif %}
        <div class="cm-fit-pills cm-tabs-nav">
          {% for block in section.blocks %}
            <button class="cm-pill {% if forloop.first %}active{% endif %}" data-tab-btn="{{ block.settings.size_name | handleize }}">{{ block.settings.size_name }}</button>
          {% endfor %}
        </div>
      </div>
    </div>
    <div class="cm-tabs-content">
      {% for block in section.blocks %}
        <div class="cm-tab-panel {% if forloop.first %}active{% endif %}" data-tab-panel="{{ block.settings.size_name | handleize }}">
          {% assign collection = block.settings.collection %}
          {% if collection != blank %}
            <div class="cm-fit-controls">
              <h3 class="cm-fit-title">{{ collection.title }} <a href="{{ block.settings.view_all_link }}" class="cm-view-all">View All {{ collection.title }}</a></h3>
              <div class="cm-arrows">
                <button class="cm-arrow prev" aria-label="previous">&lsaquo;</button>
                <button class="cm-arrow next" aria-label="next">&rsaquo;</button>
              </div>
            </div>
            <div class="swiper cm-fit-swiper">
              <div class="swiper-wrapper">
                {% for product in collection.products limit: 6 %}
                  <div class="swiper-slide">
                    <div class="cm-product-card">
                      <a href="{{ product.url }}" class="cm-product-img">
                        {{ product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy' }}
                      </a>
                      <div class="cm-product-info">
                        <a href="{{ product.url }}"><h5>{{ product.title }}</h5></a>
                        <div class="cm-product-price">
                          {% if product.compare_at_price > product.price %}
                            <span class="cm-price-old">{{ product.compare_at_price | money }}</span>
                          {% endif %}
                          <span class="cm-price-current">{{ product.price | money }}</span>
                        </div>
                        <a href="{{ product.url }}" class="cm-shop-btn">SHOP NOW</a>
                      </div>
                    </div>
                  </div>
                {% endfor %}
              </div>
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Fit Your Space",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "FIND YOUR PERFECT FIT"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FIT YOUR SPACE"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "image_picker",
      "id": "badge_image",
      "label": "Badge Image"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "size_tab",
      "name": "Size Tab",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "size_name",
          "label": "Size name",
          "default": "Twin XL"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "url",
          "id": "view_all_link",
          "label": "View all link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Fit Your Space",
      "blocks": [
        {
          "type": "size_tab",
          "settings": {
            "size_name": "Twin XL"
          }
        },
        {
          "type": "size_tab",
          "settings": {
            "size_name": "Full"
          }
        },
        {
          "type": "size_tab",
          "settings": {
            "size_name": "Queen"
          }
        },
        {
          "type": "size_tab",
          "settings": {
            "size_name": "King"
          }
        },
        {
          "type": "size_tab",
          "settings": {
            "size_name": "Split Queen"
          }
        }
      ]
    }
  ]
}
{% endschema %}
