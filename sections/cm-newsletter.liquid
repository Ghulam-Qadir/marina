{{ 'cm-newsletter.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

<div class="cm-nl-section section-{{ section.id }}-padding">
  <div class="cm-nl-inner">
    <div class="cm-nl-left">
      <span class="cm-nl-eyebrow">{{ section.settings.eyebrow }}</span>
      <div class="cm-nl-title">{{ section.settings.title }}</div>
      {%- if section.settings.subtext != blank -%}
        <p class="cm-nl-subtext">{{ section.settings.subtext }}</p>
      {%- endif -%}
    </div>

    <div class="cm-nl-right">
      {%- form 'customer', id: 'NewsletterForm', class: 'cm-nl-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <input type="hidden" name="contact[context]" value="newsletter_section">
        <div class="cm-nl-form-row">
          <input
            type="email"
            name="contact[email]"
            class="cm-nl-input"
            placeholder="Enter your email"
            autocomplete="email"
            required
            aria-label="Email address"
          >
          <button type="submit" class="cm-nl-btn" aria-label="Subscribe">
            Subscribe
          </button>
        </div>
      {%- endform -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "CM Newsletter",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "SIGN-UP TO OUR"
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Title",
      "default": "<p><strong>NEWSLETTER</strong><br><strong>AND SAVE 10% ON</strong></p>"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Your first purchase"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "CM Newsletter"
    }
  ]
}
{% endschema %}
