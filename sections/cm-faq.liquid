{{ 'cm-faq.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

<div class="cm-faq-section section-{{ section.id }}-padding">
  <div class="cm-faq-container">
    <div class="cm-faq-header">
      <span class="cm-faq-eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="cm-faq-heading">{{ section.settings.heading }}</h2>
    </div>

    <div class="cm-faq-accordion">
      {%- for block in section.blocks -%}
        {%- if block.type == 'faq_item' -%}
          <div class="accordion-item" {{ block.shopify_attributes }}>
            <h3 class="accordion-header">
              <button
                class="accordion-button"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#faq-{{ section.id }}-{{ forloop.index }}"
                aria-expanded="{% if forloop.first %}true{% else %}false{% endif %}"
                aria-controls="faq-{{ section.id }}-{{ forloop.index }}"
              >
                {{ block.settings.question }}
              </button>
            </h3>
            <div
              id="faq-{{ section.id }}-{{ forloop.index }}"
              class="accordion-collapse collapse {% if forloop.first %}show{% endif %}"
              data-bs-parent="#cm-faq-accordion-{{ section.id }}"
            >
              <div class="accordion-body">
                {{ block.settings.answer }}
              </div>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="cm-qa-banner">
      <div class="cm-qa-banner-inner">
        {%- if section.settings.banner_image -%}
          <img
            class="cm-qa-banner-img"
            src="{{ section.settings.banner_image | image_url: width: 1400 }}"
            alt="{{ section.settings.banner_image.alt | escape }}"
            width="{{ section.settings.banner_image.width }}"
            height="{{ section.settings.banner_image.height }}"
            loading="lazy"
          >
        {%- endif -%}
        <div class="cm-qa-banner-overlay"></div>
        <div class="cm-qa-banner-content">
          <span class="cm-qa-banner-small">{{ section.settings.banner_small }}</span>
          <h3 class="cm-qa-title">{{ section.settings.banner_title }}</h3>
          {%- if section.settings.banner_text != blank -%}
            <p class="cm-qa-banner-text">{{ section.settings.banner_text }}</p>
          {%- endif -%}
        </div>
      </div>
    </div>

    <div class="cm-qa-cards">
      {%- for block in section.blocks -%}
        {%- if block.type == 'contact_card' -%}
          <div class="cm-qa-card" {{ block.shopify_attributes }}>
            <div class="cm-qa-icon-box">
              {{ block.settings.icon_svg }}
            </div>
            <h4 class="cm-qa-card-title">{{ block.settings.title }}</h4>
            {%- if block.settings.description != blank -%}
              <p class="cm-qa-card-desc">{{ block.settings.description }}</p>
            {%- endif -%}
            {%- if block.settings.phone != blank -%}
              <a href="tel:{{ block.settings.phone }}" class="cm-qa-card-phone">{{ block.settings.phone }}</a>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const buttons = document.querySelectorAll('.cm-faq-accordion .accordion-button');
    buttons.forEach(function(btn) {
      btn.addEventListener('click', function() {
        const wasExpanded = this.getAttribute('aria-expanded') === 'true';
        buttons.forEach(function(b) {
          b.setAttribute('aria-expanded', 'false');
          b.classList.add('collapsed');
          const target = document.querySelector(b.getAttribute('data-bs-target'));
          if (target) target.classList.remove('show');
        });
        if (!wasExpanded) {
          this.setAttribute('aria-expanded', 'true');
          this.classList.remove('collapsed');
          const target = document.querySelector(this.getAttribute('data-bs-target'));
          if (target) target.classList.add('show');
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "CM FAQ",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "FREQUENTLY ASKED"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "QUESTIONS"
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner Image"
    },
    {
      "type": "text",
      "id": "banner_small",
      "label": "Banner Small Text",
      "default": "Still"
    },
    {
      "type": "text",
      "id": "banner_title",
      "label": "Banner Title",
      "default": "Have Questions?"
    },
    {
      "type": "textarea",
      "id": "banner_text",
      "label": "Banner Text"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer"
        }
      ]
    },
    {
      "type": "contact_card",
      "name": "Contact Card",
      "settings": [
        {
          "type": "textarea",
          "id": "icon_svg",
          "label": "Icon SVG"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "text",
          "id": "phone",
          "label": "Phone"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "CM FAQ"
    }
  ]
}
{% endschema %}
