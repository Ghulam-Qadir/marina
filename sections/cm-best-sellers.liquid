{{ 'cm-best-sellers.css' | asset_url | stylesheet_tag }}

<div class="cm-bs-section">
  <div class="cm-bs-wrap">
    {% if section.settings.eyebrow != blank %}
      <span class="cm-bs-eyebrow">{{ section.settings.eyebrow }}</span>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h2 class="cm-bs-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.description != blank %}
      <div class="cm-bs-description">{{ section.settings.description }}</div>
    {% endif %}

    <div class="cm-bs-main">
      <div class="cm-bs-promo">
        {% if section.settings.promo_image != blank %}
          <img
            src="{{ section.settings.promo_image | image_url: width: 800 }}"
            alt="{{ section.settings.promo_image.alt | escape }}"
            class="cm-bs-promo-img"
            width="{{ section.settings.promo_image.width }}"
            height="{{ section.settings.promo_image.height }}"
            loading="lazy"
          >
        {% else %}
          {{ 'lifestyle-2' | placeholder_svg_tag: 'cm-bs-promo-img cm-bs-promo-placeholder' }}
        {% endif %}

        <div class="cm-bs-promo-box">
          {% if section.settings.promo_small != blank %}
            <span class="cm-bs-promo-small">{{ section.settings.promo_small }}</span>
          {% endif %}
          {% if section.settings.promo_large != blank %}
            <span class="cm-bs-promo-large">{{ section.settings.promo_large }}</span>
          {% endif %}
        </div>
      </div>

      <div class="cm-bs-cards">
        {% if section.settings.collection != blank %}
          {% for product in section.settings.collection.products limit: 4 %}
            <div class="cm-bs-card">
              {% if product.compare_at_price > product.price %}
                <span class="cm-bs-badge">Sale</span>
              {% endif %}

              <div class="cm-bs-card-img">
                {% if product.featured_image != blank %}
                  <img
                    src="{{ product.featured_image | image_url: width: 400 }}"
                    alt="{{ product.featured_image.alt | escape }}"
                    class="cm-bs-card-product-img"
                    width="{{ product.featured_image.width }}"
                    height="{{ product.featured_image.height }}"
                    loading="lazy"
                  >
                {% else %}
                  {{ 'product-1' | placeholder_svg_tag: 'cm-bs-card-product-img cm-bs-card-placeholder' }}
                {% endif %}
              </div>

              <div class="cm-bs-card-info">
                {% if product.title != blank %}
                  <h3 class="cm-bs-card-title">{{ product.title }}</h3>
                {% endif %}

                <div class="cm-bs-card-rating">
                  <span class="cm-bs-stars">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                      <path d="M7 0L8.76 4.56L13.68 5.08L9.94 8.38L11.04 13.24L7 10.64L2.96 13.24L4.06 8.38L0.32 5.08L5.24 4.56L7 0Z" fill="#D90000"/>
                    </svg>
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                      <path d="M7 0L8.76 4.56L13.68 5.08L9.94 8.38L11.04 13.24L7 10.64L2.96 13.24L4.06 8.38L0.32 5.08L5.24 4.56L7 0Z" fill="#D90000"/>
                    </svg>
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                      <path d="M7 0L8.76 4.56L13.68 5.08L9.94 8.38L11.04 13.24L7 10.64L2.96 13.24L4.06 8.38L0.32 5.08L5.24 4.56L7 0Z" fill="#D90000"/>
                    </svg>
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                      <path d="M7 0L8.76 4.56L13.68 5.08L9.94 8.38L11.04 13.24L7 10.64L2.96 13.24L4.06 8.38L0.32 5.08L5.24 4.56L7 0Z" fill="#D90000"/>
                    </svg>
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                      <path d="M7 0L8.76 4.56L13.68 5.08L9.94 8.38L11.04 13.24L7 10.64L2.96 13.24L4.06 8.38L0.32 5.08L5.24 4.56L7 0Z" fill="#D90000"/>
                    </svg>
                  </span>
                </div>

                <div class="cm-bs-card-price">
                  {% if product.compare_at_price > product.price %}
                    <span class="cm-bs-compare-price">{{ product.compare_at_price | money }}</span>
                  {% endif %}
                  <span class="cm-bs-sale-price">{{ product.price | money }}</span>
                </div>

                <a href="{{ product.url }}" class="cm-bs-card-btn">Shop Now</a>
              </div>
            </div>
          {% endfor %}
        {% else %}
          {% for i in (1..4) %}
            <div class="cm-bs-card">
              <div class="cm-bs-card-img">
                {{ 'product-' | append: i | placeholder_svg_tag: 'cm-bs-card-product-img cm-bs-card-placeholder' }}
              </div>
              <div class="cm-bs-card-info">
                <h3 class="cm-bs-card-title">Product Title</h3>
                <div class="cm-bs-card-rating">
                  <span class="cm-bs-stars">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                      <path d="M7 0L8.76 4.56L13.68 5.08L9.94 8.38L11.04 13.24L7 10.64L2.96 13.24L4.06 8.38L0.32 5.08L5.24 4.56L7 0Z" fill="#D90000"/>
                    </svg>
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                      <path d="M7 0L8.76 4.56L13.68 5.08L9.94 8.38L11.04 13.24L7 10.64L2.96 13.24L4.06 8.38L0.32 5.08L5.24 4.56L7 0Z" fill="#D90000"/>
                    </svg>
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                      <path d="M7 0L8.76 4.56L13.68 5.08L9.94 8.38L11.04 13.24L7 10.64L2.96 13.24L4.06 8.38L0.32 5.08L5.24 4.56L7 0Z" fill="#D90000"/>
                    </svg>
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                      <path d="M7 0L8.76 4.56L13.68 5.08L9.94 8.38L11.04 13.24L7 10.64L2.96 13.24L4.06 8.38L0.32 5.08L5.24 4.56L7 0Z" fill="#D90000"/>
                    </svg>
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                      <path d="M7 0L8.76 4.56L13.68 5.08L9.94 8.38L11.04 13.24L7 10.64L2.96 13.24L4.06 8.38L0.32 5.08L5.24 4.56L7 0Z" fill="#D90000"/>
                    </svg>
                  </span>
                </div>
                <div class="cm-bs-card-price">
                  <span class="cm-bs-sale-price">$0.00</span>
                </div>
                <a href="#" class="cm-bs-card-btn">Shop Now</a>
              </div>
            </div>
          {% endfor %}
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "CM Best Sellers",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "OUR BEST"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "BEST SELLERS"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "image_picker",
      "id": "promo_image",
      "label": "Promo Image"
    },
    {
      "type": "text",
      "id": "promo_small",
      "label": "Promo Small Text",
      "default": "Shop Our Best Sellers"
    },
    {
      "type": "text",
      "id": "promo_large",
      "label": "Promo Large Text",
      "default": "Best\nDiscounts"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "CM Best Sellers"
    }
  ]
}
{% endschema %}
