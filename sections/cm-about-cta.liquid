{{ 'cm-about-cta.css' | asset_url | stylesheet_tag }}

<section class="cm-about-cta">
  <div class="cm-about-cta-bg">
    {%- if section.settings.image != blank -%}
      <img
        src="{{ section.settings.image | image_url: width: 3840 }}"
        alt="{{ section.settings.image.alt | escape }}"
        width="{{ section.settings.image.width }}"
        height="{{ section.settings.image.height }}"
        loading="lazy"
      >
    {%- else -%}
      {{ 'lifestyle-2' | placeholder_svg_tag }}
    {%- endif -%}
  </div>
  <div class="cm-about-cta-overlay"></div>
  <div class="cm-about-cta-content">
    {%- if section.settings.eyebrow != blank -%}
      <span class="cm-about-cta-eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="cm-about-cta-heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.text != blank -%}
      <p class="cm-about-cta-text">{{ section.settings.text }}</p>
    {%- endif -%}

    {%- if section.settings.btn_label != blank -%}
      <a href="{{ section.settings.btn_link }}" class="cm-about-cta-btn">
        {{ section.settings.btn_label }}
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "CM About CTA",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "READY TO SLEEP BETTER?"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Start Your Sleep Journey"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Take our mattress quiz and discover the perfect match for your sleep style."
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button Label",
      "default": "Take the Mattress Quiz"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    }
  ],
  "presets": [
    {
      "name": "CM About CTA"
    }
  ]
}
{% endschema %}
