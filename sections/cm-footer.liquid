{{ 'cm-footer.css' | asset_url | stylesheet_tag }}

<!-- Newsletter CTA Section -->
<div class="cta-section">
  <div class="page-width">
    <div class="nl-inner">
      <div class="nl-left">
        {% if section.settings.newsletter_eyebrow != blank %}
          <p class="nl-eyebrow">{{ section.settings.newsletter_eyebrow }}</p>
        {% endif %}
        {% if section.settings.newsletter_title != blank %}
          <h2 class="nl-title">{{ section.settings.newsletter_title }}</h2>
        {% endif %}
      </div>
      <div class="nl-right">
        {% form 'customer', id: 'newsletter-form' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="nl-form-inner">
            <input
              type="email"
              name="contact[email]"
              class="nl-input"
              placeholder="Enter your email"
              required
              autocomplete="email"
            >
            <button type="submit" class="nl-submit">Subscribe</button>
          </div>
        {% endform %}
      </div>
    </div>
  </div>
</div>

<!-- Footer Section -->
<footer class="footer-bg">
  <div class="page-width">
    <div class="footer-grid">
      <!-- Left Column: Logo + Info -->
      <div class="footer-col footer-col-left">
        {% if section.settings.footer_logo != blank %}
          <div class="footer-logo">
            <img src="{{ section.settings.footer_logo | image_url: width: 200 }}" alt="{{ shop.name }}" width="{{ section.settings.footer_logo.width }}" height="{{ section.settings.footer_logo.height }}">
          </div>
        {% else %}
          <div class="footer-logo-text">{{ shop.name }}</div>
        {% endif %}

        {% if section.settings.heading != blank %}
          <p class="footer-heading">{{ section.settings.heading }}</p>
        {% endif %}

        {% if section.settings.description != blank %}
          <p class="footer-description">{{ section.settings.description }}</p>
        {% endif %}

        {% if section.settings.phone_number != blank %}
          <a href="tel:{{ section.settings.phone_number | remove: '-' | remove: ' ' }}" class="footer-call-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            Call Us: {{ section.settings.phone_number }}
          </a>
          {% if section.settings.phone_hours != blank %}
            <p class="footer-phone-hours">{{ section.settings.phone_hours }}</p>
          {% endif %}
        {% endif %}

        {% if section.settings.address != blank %}
          <div class="footer-address">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            {{ section.settings.address | newline_to_br }}
          </div>
        {% endif %}
      </div>

      <!-- Middle Column: Popular Brands -->
      <div class="footer-col footer-col-middle">
        <h3 class="footer-menu-title">Popular Brands</h3>
        <ul class="footer-menu">
          {% for block in section.blocks %}
            {% if block.type == 'brand_link' %}
              <li {{ block.shopify_attributes }}>
                <a href="{{ block.settings.url }}" class="footer-link">
                  <span class="footer-link-check"></span>
                  {{ block.settings.label }}
                </a>
              </li>
            {% endif %}
          {% endfor %}
        </ul>
      </div>

      <!-- Right Column: Information & Company -->
      <div class="footer-col footer-col-right">
        <div class="footer-menu-group">
          <h3 class="footer-menu-title">Information</h3>
          <ul class="footer-menu">
            {% for block in section.blocks %}
              {% if block.type == 'info_link' %}
                <li {{ block.shopify_attributes }}>
                  <a href="{{ block.settings.url }}" class="footer-link">
                    <span class="footer-link-check"></span>
                    {{ block.settings.label }}
                  </a>
                </li>
              {% endif %}
            {% endfor %}
          </ul>
        </div>
        <div class="footer-menu-group">
          <h3 class="footer-menu-title">Company</h3>
          <ul class="footer-menu">
            {% for block in section.blocks %}
              {% if block.type == 'company_link' %}
                <li {{ block.shopify_attributes }}>
                  <a href="{{ block.settings.url }}" class="footer-link">
                    <span class="footer-link-check"></span>
                    {{ block.settings.label }}
                  </a>
                </li>
              {% endif %}
            {% endfor %}
          </ul>
        </div>
      </div>
    </div>
  </div>
</footer>

<!-- Footer Bottom Bar -->
<div class="footer-bar">
  <div class="page-width">
    <div class="footer-bar-inner">
      <div class="footer-bar-left">
        <p class="footer-copyright">&copy; {{ 'now' | date: "%Y" }} {{ shop.name }}. All rights reserved.</p>
      </div>

      <div class="footer-bar-center">
        <div class="footer-social">
          {% for block in section.blocks %}
            {% if block.type == 'social_link' %}
              <a href="{{ block.settings.url }}" class="footer-social-icon" target="_blank" rel="noopener" {{ block.shopify_attributes }}>
                {% case block.settings.icon %}
                  {% when 'facebook' %}
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
                  {% when 'youtube' %}
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19.1c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"></path><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon></svg>
                  {% when 'instagram' %}
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
                  {% when 'x' %}
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path></svg>
                {% endcase %}
              </a>
            {% endif %}
          {% endfor %}
        </div>
      </div>

      <div class="footer-bar-right">
        <div class="footer-payments">
          {% assign payment_types = 'paypal,visa,master,apple_pay,google_pay' | split: ',' %}
          {% for type in payment_types %}
            {% case type %}
              {% when 'paypal' %}
                {% if shop.enabled_payment_types contains 'paypal' %}
                  {{ type | payment_type_svg_tag }}
                {% endif %}
              {% when 'visa' %}
                {% if shop.enabled_payment_types contains 'visa' %}
                  {{ type | payment_type_svg_tag }}
                {% endif %}
              {% when 'master' %}
                {% if shop.enabled_payment_types contains 'master' %}
                  {{ type | payment_type_svg_tag }}
                {% endif %}
              {% when 'apple_pay' %}
                {% if shop.enabled_payment_types contains 'apple_pay' %}
                  {{ type | payment_type_svg_tag }}
                {% endif %}
              {% when 'google_pay' %}
                {% if shop.enabled_payment_types contains 'google_pay' %}
                  {{ type | payment_type_svg_tag }}
                {% endif %}
              {% else %}
                <span class="footer-payment-text">{{ type | capitalize | replace: '_', ' ' }}</span>
            {% endcase %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
